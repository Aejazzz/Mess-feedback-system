// Amrita Food Feedback — PostgreSQL (see .env.example / docker-compose.yml)

generator client {
  provider      = "prisma-client-js"
  // Vercel runs Linux; include so `prisma generate` on Windows still produces a deployable client.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Feedback {
  id        String   @id @default(cuid())
  mealType  String
  block     String
  rating    Int
  review    String?
  date      String
  day       String
  createdAt DateTime @default(now())

  @@index([date])
  @@index([mealType])
  @@index([block])
}
