# Copy to .env or .env.local (Prisma reads .env; Next.js reads .env.local too)

# Use this with Docker Compose Postgres in this repo. Do NOT use prisma+postgres:// here
# unless you intentionally run `prisma dev` / Prisma Postgres on that port.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/amrita_feedback?schema=public"

# Optional: used by QR page fallbacks when window origin is unavailable
NEXT_PUBLIC_APP_URL="http://localhost:3000"
